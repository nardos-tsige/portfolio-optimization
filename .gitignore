gitignore = """
# Python
__pycache__/
*.pyc
venv/
env/
*.so
*.egg-info/

# Jupyter
.ipynb_checkpoints/

# Data - Keep processed data but ignore raw
data/raw/
data/processed/*.csv
data/processed/*.png
!data/processed/.gitkeep

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Logs
*.log
*.zip

# Results
results/
"""

with open('.gitignore', 'w') as f:
    f.write(gitignore.strip())
print("✓ Updated: .gitignore")